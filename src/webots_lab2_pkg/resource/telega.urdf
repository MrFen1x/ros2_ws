      <geometry>
        <box size="0.24 0.17 0.11"/>
        <!-- Границы для обнаружения столкновений -->
      </geometry>
    </collision>
    <inertial>
      <mass value="1.067"/>
      <!-- Масса корпуса, кг -->
      <!-- Моменты инерции корпуса (упрощённо, для прямоугольника) -->
      <inertia ixx="0.05" ixy="0.0" ixz="0.0" iyy="0.05" iyz="0.0" izz="0.05"/>
    </inertial>
  </link>
